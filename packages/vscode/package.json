{
  "name": "ukdl",
  "displayName": "UKDL - Unified Knowledge & Dynamics Language",
  "description": "Syntax highlighting, snippets, and language support for UKDL",
  "version": "2.0.0",
  "publisher": "ukdl",
  "engines": {"vscode": "^1.85.0"},
  "categories": ["Programming Languages", "Snippets", "Formatters"],
  "icon": "icon.png",
  "activationEvents": ["onLanguage:ukdl"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [{
      "id": "ukdl",
      "aliases": ["UKDL", "ukdl", "Unified Knowledge & Dynamics Language"],
      "extensions": [".ukdl"],
      "configuration": "./language-configuration.json",
      "icon": {"light": "./icon.png", "dark": "./icon.png"}
    }],
    "grammars": [{
      "language": "ukdl",
      "scopeName": "source.ukdl",
      "path": "./syntaxes/ukdl.tmLanguage.json"
    }],
    "themes": [{
      "label": "UKDL Dark",
      "uiTheme": "vs-dark",
      "path": "./themes/ukdl-dark.json"
    }],
    "snippets": [{
      "language": "ukdl",
      "path": "./snippets/ukdl.json"
    }]
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
